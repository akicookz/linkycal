{
	"name": "linkycal",
	"private": true,
	"version": "0.0.0",
	"type": "module",
	"scripts": {
		"dev": "vite",
		"build": "bun run cf-typegen && tsc -b && vite build",
		"lint": "eslint .",
		"preview": "bun run build && vite preview",
		"deploy": "bun run build && wrangler deploy",
		"cf-typegen": "wrangler types",
		"db:generate": "drizzle-kit generate",
		"db:migrate:dev": "bun run wrangler d1 migrations apply --local DB",
		"db:migrate:prod": "bun run wrangler d1 migrations apply --remote DB",
		"widget:build:booking": "vite build --config widget/booking/vite.config.ts",
		"widget:build:form": "vite build --config widget/form/vite.config.ts",
		"widget:build": "bun run widget:build:booking && bun run widget:build:form",
		"widget:upload": "wrangler r2 object put linkycal-uploads/widgets/booking.js --file dist-widget/booking-widget.js --content-type application/javascript --remote && wrangler r2 object put linkycal-uploads/widgets/form.js --file dist-widget/form-widget.js --content-type application/javascript --remote",
		"widget:deploy": "bun run widget:build && bun run widget:upload",
		"deploy:full": "bun run build && bun run widget:deploy && wrangler deploy && bun run db:migrate:prod"
	},
	"dependencies": {
		"@dnd-kit/core": "^6.3.1",
		"@dnd-kit/sortable": "^10.0.0",
		"@dnd-kit/utilities": "^3.2.2",
		"@radix-ui/react-avatar": "^1.1.10",
		"@radix-ui/react-collapsible": "^1.1.11",
		"@radix-ui/react-dialog": "^1.1.14",
		"@radix-ui/react-dropdown-menu": "^2.1.15",
		"@radix-ui/react-label": "^2.1.7",
		"@radix-ui/react-popover": "^1.1.14",
		"@radix-ui/react-select": "^2.2.5",
		"@radix-ui/react-separator": "^1.1.7",
		"@radix-ui/react-slot": "^1.2.3",
		"@radix-ui/react-switch": "^1.2.5",
		"@radix-ui/react-tabs": "^1.1.12",
		"@radix-ui/react-tooltip": "^1.2.7",
		"@tailwindcss/vite": "^4.1.7",
		"@tanstack/react-query": "^5.77.0",
		"better-auth": "~1.4.18",
		"better-auth-cloudflare": "^0.2.9",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"drizzle-orm": "^0.45.1",
		"googleapis": "^144.0.0",
		"hono": "^4.11.7",
		"lucide-react": "^0.563.0",
		"react": "^19.1.0",
		"react-dom": "^19.1.0",
		"react-router-dom": "^7.6.0",
		"resend": "^6.9.1",
		"stripe": "^20.4.0",
		"tailwind-merge": "^3.3.0",
		"tailwindcss": "^4.1.7",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@cloudflare/vite-plugin": "^1.2.4",
		"@cloudflare/workers-types": "4.20260305.0",
		"@eslint/js": "^9.25.0",
		"@tanstack/react-query-devtools": "^5.77.0",
		"@types/node": "^22.15.21",
		"@types/react": "^19.1.2",
		"@types/react-dom": "^19.1.2",
		"@types/react-router-dom": "^5.3.3",
		"@vitejs/plugin-react-swc": "^3.9.0",
		"drizzle-kit": "^0.31.8",
		"eslint": "^9.25.0",
		"eslint-plugin-react-hooks": "^5.2.0",
		"eslint-plugin-react-refresh": "^0.4.19",
		"globals": "^16.0.0",
		"terser": "^5.46.1",
		"tw-animate-css": "^1.3.0",
		"typescript": "~5.8.3",
		"typescript-eslint": "^8.30.1",
		"vite": "^6.3.5",
		"wrangler": "^4.16.1"
	}
}
